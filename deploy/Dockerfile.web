FROM node:20-bookworm-slim AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund

COPY . .

ARG VITE_VARIANT=full
RUN case "$VITE_VARIANT" in \
  full|tech|finance|happy) npm run "build:${VITE_VARIANT}" ;; \
  *) echo "Unsupported VITE_VARIANT=$VITE_VARIANT" && exit 1 ;; \
  esac

FROM nginx:1.27-alpine AS runtime

COPY deploy/nginx/worldmonitor-selfhost.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
