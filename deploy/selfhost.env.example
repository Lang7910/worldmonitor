# ---------- Public web ----------
APP_PORT=8080
VITE_VARIANT=full

# ---------- Relay profile ----------
# auto: enable relay only when AISSTREAM_API_KEY is set
# true: always enable relay profile
# false: disable relay profile
ENABLE_RELAY=auto

# ---------- Local API runtime ----------
LOCAL_API_CLOUD_FALLBACK=false
LOCAL_API_YOUTUBE_LIVE_MODE=local

# ---------- Relay connection (API -> relay) ----------
WS_RELAY_URL=http://relay:3004
RELAY_SHARED_SECRET=
RELAY_AUTH_HEADER=x-relay-key
ALLOW_UNAUTHENTICATED_RELAY=false

# ---------- AI providers ----------
OLLAMA_API_URL=
OLLAMA_MODEL=
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ---------- Core data providers ----------
FINNHUB_API_KEY=
FRED_API_KEY=
EIA_API_KEY=
ACLED_ACCESS_TOKEN=
UCDP_ACCESS_TOKEN=
CLOUDFLARE_API_TOKEN=
NASA_FIRMS_API_KEY=
WINGBITS_API_KEY=
WTO_API_KEY=
AVIATIONSTACK_API=
ICAO_API_KEY=

# ---------- Threat feeds ----------
URLHAUS_AUTH_KEY=
OTX_API_KEY=
ABUSEIPDB_API_KEY=

# ---------- Relay upstreams (for full live tracking) ----------
AISSTREAM_API_KEY=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNEL_SET=full

# ---------- Optional registration DB ----------
CONVEX_URL=

# ---------- Optional cache ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
